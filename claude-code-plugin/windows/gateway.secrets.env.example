# gateway.secrets.env.example
#
# Copy this file to "gateway.secrets.env" (same directory) and fill in your
# real keys. gateway.secrets.env is gitignored and MUST NEVER be committed.
#
# start-gateway.ps1 loads every KEY=VALUE line below and injects it into the
# gateway process environment. The gateway's config (tdai-gateway.yaml) then
# resolves ${OPENAI_API_KEY} etc. from that environment.
#
# Format: KEY=VALUE, one per line. Lines starting with '#' are comments.
# Surrounding single/double quotes around a VALUE are stripped.

# Embeddings provider key (OpenAI-compatible). Required for semantic search.
# Without it the embedding provider initialises as disabled and search falls
# back to keyword-only.
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Optional: extraction LLM (L1/L2/L3) if you prefer to pin it here instead of
# relying on the Windows User environment.
# TDAI_LLM_BASE_URL=https://api.openai.com/v1
# TDAI_LLM_API_KEY=sk-your-llm-key-here
# TDAI_LLM_MODEL=gpt-4o-mini
